// ---------------- SAFETY LOGIC ----------------
String getSafetyVerdict(float gasVOC, float humidity, float temp) {
  if (humidity > 80)                    return "DO NOT EAT";
  if (temp > 30 && gasVOC < 10000)      return "DO NOT EAT";
  if (gasVOC < 1000)                    return "DO NOT EAT";
  if (gasVOC < 10000)                   return "WARNING";
  if (gasVOC < 50000)                   return "CAUTION";
  return "SAFE";
}

String getSafetyReason(float gasVOC, float humidity, float temp) {
  if (humidity > 80)                    return "Too humid - mold risk!";
  if (temp > 30 && gasVOC < 10000)      return "High temp + chemicals detected!";
  if (gasVOC < 1000)                    return "Very strong chemicals detected!";
  if (gasVOC < 10000)                   return "Chemicals detected - wash produce well!";
  if (gasVOC < 50000)                   return "Slight chemicals - wash before eating";
  return "Air is clean, no chemicals detected";
}

// ---------------- DATE TIME ----------------
String getFormattedDateTime() {
  timeClient.update();
  time_t rawTime = (time_t)timeClient.getEpochTime();
  struct tm *ptm = gmtime(&rawTime);

  char buf[30];
  sprintf(buf, "%04d-%02d-%02d %02d:%02d:%02d",
    ptm->tm_year + 1900,
    ptm->tm_mon + 1,
    ptm->tm_mday,
    ptm->tm_hour,
    ptm->tm_min,
    ptm->tm_sec);
  return String(buf);
}

// ---------------- SETUP ----------------
void setup() {
  Serial.begin(115200);
  delay(2000);
  Serial.println("\n\nBooting...");

  Wire.begin(SDA_PIN, SCL_PIN);
  delay(500);

  if (!bme.begin(0x77)) {
    Serial.println(" BME680 not found!");
    while (1);
  }
  bme.setTemperatureOversampling(BME680_OS_8X);
  bme.setHumidityOversampling(BME680_OS_2X);
  bme.setPressureOversampling(BME680_OS_4X);
  bme.setGasHeater(320, 150);
  Serial.println(" BME680 OK!");

  // WiFi
  WiFi.begin(WIFI_SSID, WIFI_PASSWORD);
  Serial.print("Connecting to WiFi");
  int attempts = 0;
  while (WiFi.status() != WL_CONNECTED && attempts < 20) {
    delay(500);
    Serial.print(".");
    attempts++;
  }
  if (WiFi.status() != WL_CONNECTED) {
    Serial.println("\n WiFi Failed!");
    while (1);
  }
  Serial.println("\n WiFi connected! IP: " + WiFi.localIP().toString());

  // NTP
  timeClient.begin();
  timeClient.update();
  Serial.println(" NTP Time: " + getFormattedDateTime());

  // Firebase
  config.api_key = API_KEY;
  config.database_url = DATABASE_URL;
  config.token_status_callback = tokenStatusCallback;
  Firebase.signUp(&config, &auth, "", "");
  Firebase.begin(&config, &auth);
  Firebase.reconnectWiFi(true);
  Serial.println(" Firebase ready!");
}

// ---------------- LOOP ----------------
void loop() {
  if (bme.performReading()) {
    float temp     = bme.temperature;
    float humidity = bme.humidity;
    float pressure = bme.pressure / 100.0;
    float gasVOC   = bme.gas_resistance;

    String verdict   = getSafetyVerdict(gasVOC, humidity, temp);
    String reason    = getSafetyReason(gasVOC, humidity, temp);
    String dateTime  = getFormattedDateTime();
    unsigned long ts = timeClient.getEpochTime(); 

    Serial.println("===========================================");
    Serial.print("DateTime: "); Serial.println(dateTime);
    Serial.print("Temp:     "); Serial.print(temp);     Serial.println(" C");
    Serial.print("Humidity: "); Serial.print(humidity);  Serial.println(" %");
    Serial.print("Pressure: "); Serial.print(pressure);  Serial.println(" hPa");
    Serial.print("Gas VOC:  "); Serial.print(gasVOC);   Serial.println(" ohms");
    Serial.println("RESULT: "  + verdict);
    Serial.println("REASON: "  + reason);
    Serial.println("===========================================");

    if (Firebase.ready() && millis() - sendDataTimer > 5000) {
      sendDataTimer = millis();

      FirebaseJson json;
      json.set("dateTime",    dateTime);
      json.set("timestamp",   (int)ts);  
      json.set("temperature", temp);
      json.set("humidity",    humidity);
      json.set("pressure",    pressure);
      json.set("gasVOC",      gasVOC);
      json.set("verdict",     verdict);
      json.set("reason",      reason);

      if (Firebase.RTDB.pushJSON(&fbdo, "/scans", &json)) {
        Serial.println(" Data pushed to /scans [" + dateTime + "]");
      } else {
        Serial.println(" Firebase Error: " + fbdo.errorReason());
      }
    }
  }
  delay(2000);
}
